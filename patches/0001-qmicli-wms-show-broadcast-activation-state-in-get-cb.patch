From ff3b61e08c244cffac729fc2199016161d9e7bf7 Mon Sep 17 00:00:00 2001
From: seidnerj <4147381+seidnerj@users.noreply.github.com>
Date: Mon, 9 Mar 2026 06:34:40 +0200
Subject: [PATCH 1/4] qmicli,wms: show broadcast activation state in
 get-cbs-channels output

The get-broadcast-config response includes an activation state field
that was previously not displayed. Show it as a separate line so users
can verify whether Cell Broadcast reception is currently active on
the modem.

Based on libqmi commit d125e7a5 from
https://gitlab.freedesktop.org/mobile-broadband/libqmi
---
 src/qmicli/qmicli-wms.c | 5 ++++-
 1 file changed, 4 insertions(+), 1 deletion(-)

diff --git a/src/qmicli/qmicli-wms.c b/src/qmicli/qmicli-wms.c
index b15ddba..cf2f715 100644
--- a/src/qmicli/qmicli-wms.c
+++ b/src/qmicli/qmicli-wms.c
@@ -555,7 +555,10 @@ get_broadcast_config_ready (QmiClientWms *client,
         return;
     }
 
-    g_print ("[%s] Successfully get cbs channels: ", qmi_device_get_path_display (ctx->device));
+    g_print ("[%s] CBS broadcast active: %s\n",
+             qmi_device_get_path_display (ctx->device),
+             active ? "yes" : "no");
+    g_print ("[%s] CBS channels: ", qmi_device_get_path_display (ctx->device));
 
     for (i = 0; i < channels->len; i++) {
         QmiMessageWmsGetBroadcastConfigOutputConfigChannelsElement ch;
-- 
2.53.0

